    "npx skills check",
    "npx skills update"
  ],
  "rebuildCommand": "node scripts/rebuild_kbs.js --root <project-root>",
  "capabilities": [
    "pinus-backend-kb",
    "cocos-static-call-kb",
    "frontend-http-request-kb",
    "kb-query-entrypoint",
    "kb-version-stamp",
    "kb-post-update-rebuild",
    "project-global-kb",
    "project-protocol-learning",
    "project-kb-query",
    "auto-feature-registry-sync",
    "endpoint-route-table-graph",
    "upstream-downstream-query",
    "skills-cli-install"
  ]
}
