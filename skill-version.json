  "releaseDate": "2026-03-28",
  "repo": "https://github.com/entiwee-ship-it/project-memory-manager.git",
  "upgradePolicy": "edit-source-repo-only",
  "upgradeMessage": "Never edit the installed skill copy directly. Fix the GitHub source repo, push, then reinstall or update the skill before rebuilding project KBs.",
